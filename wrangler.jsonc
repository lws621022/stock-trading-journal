{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "stock-trading-journal",
  "main": "./worker.js",
  "compatibility_date": "2026-07-11",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "binding": "ASSETS",
    "run_worker_first": [
      "/api/*"
    ]
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}

